# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=prefeitura
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=painel_social

# ─── Backend ─────────────────────────────────────────────────────────────────
# Full connection string built from the values above (used by docker compose)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# Generate a strong secret for production: openssl rand -hex 32
JWT_SECRET=change_me_in_production

PORT=8080
SEED_FILE=/app/data/seed.json
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────────────────
# Browser-facing URL of the backend API.
# In local Docker: http://localhost:8080
# In production (Vercel → Render): https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# Internal Docker network URL (used only during SSR / build inside compose)
API_URL=http://backend:8080
